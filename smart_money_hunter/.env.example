# Copy this file to `.env` and fill in your real credentials.
# Do NOT commit the real `.env` file – it is ignored by .gitignore.

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Helius API key (https://helius.xyz) — used to fetch Solana wallet transactions
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API key (https://birdeye.so) — used to fetch token prices and top tokens
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Database connection string (default: local SQLite file)
DATABASE_URL=sqlite:///smart_money.db
